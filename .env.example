# ---- Database ----
# Local dev (default): SQLite file (provider = "sqlite" in prisma/schema.prisma)
DATABASE_URL="file:./dev.db"
# Production (Neon/Supabase): provider = "postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/transitops?sslmode=require"

# ---- Auth ----
# Any long random string (used to sign session JWTs)
AUTH_SECRET="change-me-to-a-long-random-string"
